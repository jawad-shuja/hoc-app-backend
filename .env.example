# Django
SECRET_KEY=change-me-in-production
DEBUG=True
# Comma-separated. In production add your Render hostname, e.g.:
# ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com
# (RENDER_EXTERNAL_HOSTNAME is injected automatically by Render, so you
#  only need to set this if you have a custom domain or multiple hosts.)
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origin(s) allowed to call this API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Routing/geocoding — free key at https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=
